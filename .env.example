# ── Database ──
MONGODB_URI=mongodb://localhost:27017/evalats

# ── Authentication ──
JWT_SECRET=your-jwt-secret-here

# ── Application URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron Job Security ──
CRON_SECRET=your-cron-secret-here

# ── SMTP Email (optional — falls back to mailto: links) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── OpenAI (optional — powers resume parsing & AI matcher) ──
OPENAI_API_KEY=
